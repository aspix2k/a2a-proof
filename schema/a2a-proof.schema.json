{
  "$defs": {
    "AgentCapabilitiesExpectation": {
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "streaming"
          ]
        },
        {
          "required": [
            "push_notifications"
          ]
        },
        {
          "required": [
            "extended_agent_card"
          ]
        }
      ],
      "properties": {
        "extended_agent_card": {
          "title": "Extended Agent Card",
          "type": "boolean"
        },
        "push_notifications": {
          "title": "Push Notifications",
          "type": "boolean"
        },
        "streaming": {
          "title": "Streaming",
          "type": "boolean"
        }
      },
      "title": "AgentCapabilitiesExpectation",
      "type": "object"
    },
    "AgentCardExpectation": {
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "skills"
          ]
        },
        {
          "required": [
            "capabilities"
          ]
        },
        {
          "required": [
            "input_modes"
          ]
        },
        {
          "required": [
            "output_modes"
          ]
        }
      ],
      "properties": {
        "capabilities": {
          "$ref": "#/$defs/AgentCapabilitiesExpectation",
          "title": "Capabilities"
        },
        "input_modes": {
          "$ref": "#/$defs/ContainsExpectation",
          "title": "Input Modes"
        },
        "output_modes": {
          "$ref": "#/$defs/ContainsExpectation",
          "title": "Output Modes"
        },
        "skills": {
          "$ref": "#/$defs/ContainsExpectation",
          "description": "Required Agent Card skill IDs.",
          "title": "Skills"
        }
      },
      "title": "AgentCardExpectation",
      "type": "object"
    },
    "AgentConfig": {
      "additionalProperties": false,
      "properties": {
        "allow_cross_origin_interfaces": {
          "default": false,
          "description": "Allow Agent Card interfaces on another origin.",
          "title": "Allow Cross Origin Interfaces",
          "type": "boolean"
        },
        "card_path": {
          "anyOf": [
            {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom Agent Card path.",
          "title": "Card Path"
        },
        "extensions": {
          "description": "Advertised A2A extensions to activate.",
          "items": {
            "maxLength": 1000,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 20,
          "title": "Extensions",
          "type": "array"
        },
        "grpc_tls": {
          "default": true,
          "description": "Use TLS for gRPC interfaces.",
          "title": "Grpc Tls",
          "type": "boolean"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Request headers; keep values in environment variables.",
          "title": "Headers",
          "type": "object"
        },
        "timeout": {
          "default": 30,
          "description": "Turn timeout in seconds.",
          "exclusiveMinimum": 0,
          "maximum": 600,
          "title": "Timeout",
          "type": "number"
        },
        "transport": {
          "default": "auto",
          "description": "Required protocol binding or Agent Card preference.",
          "enum": [
            "auto",
            "JSONRPC",
            "HTTP+JSON",
            "GRPC"
          ],
          "title": "Transport",
          "type": "string"
        },
        "url": {
          "description": "Agent Card discovery base URL.",
          "format": "uri",
          "maxLength": 2083,
          "minLength": 1,
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "title": "AgentConfig",
      "type": "object"
    },
    "ContainsExpectation": {
      "additionalProperties": false,
      "properties": {
        "contains": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "maxLength": 200,
                "minLength": 1,
                "type": "string"
              },
              "maxItems": 100,
              "minItems": 1,
              "type": "array"
            }
          ],
          "description": "Required values.",
          "title": "Contains"
        }
      },
      "required": [
        "contains"
      ],
      "title": "ContainsExpectation",
      "type": "object"
    },
    "DataExpectation": {
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "equals"
          ]
        },
        {
          "required": [
            "exists"
          ]
        },
        {
          "required": [
            "matches"
          ]
        },
        {
          "anyOf": [
            {
              "required": [
                "gt"
              ]
            },
            {
              "required": [
                "gte"
              ]
            },
            {
              "required": [
                "lt"
              ]
            },
            {
              "required": [
                "lte"
              ]
            }
          ]
        },
        {
          "required": [
            "json_schema"
          ]
        }
      ],
      "properties": {
        "artifact_name": {
          "anyOf": [
            {
              "description": "Required artifact name.",
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Name"
        },
        "equals": {
          "anyOf": [
            {
              "$ref": "#/$defs/JsonValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Required JSON value."
        },
        "exists": {
          "description": "Whether the selected path must exist.",
          "title": "Exists",
          "type": "boolean"
        },
        "gt": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            }
          ],
          "description": "Exclusive numeric lower bound.",
          "title": "Gt"
        },
        "gte": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            }
          ],
          "description": "Inclusive numeric lower bound.",
          "title": "Gte"
        },
        "json_schema": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "object"
            },
            {
              "type": "boolean"
            }
          ],
          "description": "Inline JSON Schema Draft 2020-12 document.",
          "title": "Json Schema"
        },
        "lt": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            }
          ],
          "description": "Exclusive numeric upper bound.",
          "title": "Lt"
        },
        "lte": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            }
          ],
          "description": "Inclusive numeric upper bound.",
          "title": "Lte"
        },
        "matches": {
          "description": "Regular expression required for a string value.",
          "maxLength": 100000,
          "minLength": 1,
          "title": "Matches",
          "type": "string"
        },
        "media_type": {
          "anyOf": [
            {
              "description": "Required data-part media type.",
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Type"
        },
        "path": {
          "default": "",
          "description": "RFC 6901 JSON Pointer; empty selects the root.",
          "maxLength": 1000,
          "title": "Path",
          "type": "string"
        },
        "source": {
          "anyOf": [
            {
              "enum": [
                "message",
                "artifact"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Limit matching to message or artifact data parts.",
          "title": "Source"
        }
      },
      "title": "DataExpectation",
      "type": "object"
    },
    "Expectation": {
      "additionalProperties": false,
      "properties": {
        "data": {
          "anyOf": [
            {
              "$ref": "#/$defs/DataExpectation"
            },
            {
              "items": {
                "$ref": "#/$defs/DataExpectation"
              },
              "maxItems": 100,
              "type": "array"
            }
          ],
          "description": "Structured response checks.",
          "title": "Data"
        },
        "files": {
          "anyOf": [
            {
              "$ref": "#/$defs/FileExpectation"
            },
            {
              "items": {
                "$ref": "#/$defs/FileExpectation"
              },
              "maxItems": 100,
              "type": "array"
            }
          ],
          "description": "File-part metadata checks.",
          "title": "Files"
        },
        "max_first_event_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 600,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum time until the first response event.",
          "title": "Max First Event Seconds"
        },
        "max_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 600,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum complete turn duration.",
          "title": "Max Seconds"
        },
        "state": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Required terminal A2A state.",
          "title": "State"
        },
        "states": {
          "anyOf": [
            {
              "$ref": "#/$defs/StateSequenceExpectation"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Observed A2A state sequence checks."
        },
        "text": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextExpectation"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Response text checks."
        }
      },
      "title": "Expectation",
      "type": "object"
    },
    "FileExpectation": {
      "additionalProperties": false,
      "properties": {
        "artifact_name": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Name"
        },
        "count": {
          "default": 1,
          "description": "Required matching part count.",
          "maximum": 1000,
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "filename": {
          "anyOf": [
            {
              "maxLength": 1000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Filename"
        },
        "kind": {
          "anyOf": [
            {
              "enum": [
                "raw",
                "url"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "media_type": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Type"
        },
        "source": {
          "anyOf": [
            {
              "enum": [
                "message",
                "artifact"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        }
      },
      "title": "FileExpectation",
      "type": "object"
    },
    "FileInput": {
      "anyOf": [
        {
          "maxLength": 1000,
          "minLength": 1,
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "media_type": {
              "anyOf": [
                {
                  "description": "A2A media type.",
                  "maxLength": 200,
                  "minLength": 1,
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Media Type"
            },
            "path": {
              "description": "Path relative to the contract file.",
              "maxLength": 1000,
              "minLength": 1,
              "title": "Path",
              "type": "string"
            }
          },
          "required": [
            "path"
          ],
          "title": "FileInput",
          "type": "object"
        }
      ],
      "description": "A relative path or file input object.",
      "title": "FileInput"
    },
    "Invariants": {
      "additionalProperties": false,
      "properties": {
        "text": {
          "$ref": "#/$defs/TextInvariant"
        }
      },
      "required": [
        "text"
      ],
      "title": "Invariants",
      "type": "object"
    },
    "JsonValue": {},
    "LatencyExpectation": {
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "p50_seconds"
          ]
        },
        {
          "required": [
            "p95_seconds"
          ]
        }
      ],
      "properties": {
        "p50_seconds": {
          "description": "Maximum median trial duration.",
          "exclusiveMinimum": 0,
          "maximum": 600,
          "title": "P50 Seconds",
          "type": "number"
        },
        "p95_seconds": {
          "description": "Maximum 95th-percentile trial duration.",
          "exclusiveMinimum": 0,
          "maximum": 600,
          "title": "P95 Seconds",
          "type": "number"
        }
      },
      "title": "LatencyExpectation",
      "type": "object"
    },
    "Scenario": {
      "additionalProperties": false,
      "properties": {
        "data": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "object"
            },
            {
              "items": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "array"
            }
          ],
          "description": "Single-turn structured input.",
          "title": "Data"
        },
        "expect": {
          "$ref": "#/$defs/Expectation",
          "description": "Single-turn response."
        },
        "files": {
          "description": "Single-turn local file input.",
          "items": {
            "$ref": "#/$defs/FileInput"
          },
          "maxItems": 20,
          "title": "Files",
          "type": "array"
        },
        "latency": {
          "anyOf": [
            {
              "$ref": "#/$defs/LatencyExpectation"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Aggregate duration checks across completed trials."
        },
        "message": {
          "anyOf": [
            {
              "maxLength": 100000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Single-turn text input.",
          "title": "Message"
        },
        "name": {
          "description": "Unique scenario name.",
          "maxLength": 200,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "pass_rate": {
          "default": 1.0,
          "description": "Minimum successful trial fraction.",
          "exclusiveMinimum": 0,
          "maximum": 1,
          "title": "Pass Rate",
          "type": "number"
        },
        "trials": {
          "default": 1,
          "description": "Independent repetitions.",
          "maximum": 100,
          "minimum": 1,
          "title": "Trials",
          "type": "integer"
        },
        "turns": {
          "anyOf": [
            {
              "description": "Ordered multi-turn conversation.",
              "items": {
                "$ref": "#/$defs/Turn"
              },
              "maxItems": 50,
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Turns"
        }
      },
      "required": [
        "name"
      ],
      "title": "Scenario",
      "type": "object"
    },
    "ScenarioDefaults": {
      "additionalProperties": false,
      "properties": {
        "pass_rate": {
          "default": 1.0,
          "description": "Default minimum successful trial fraction.",
          "exclusiveMinimum": 0,
          "maximum": 1,
          "title": "Pass Rate",
          "type": "number"
        },
        "trials": {
          "default": 1,
          "description": "Default independent repetitions.",
          "maximum": 100,
          "minimum": 1,
          "title": "Trials",
          "type": "integer"
        }
      },
      "title": "ScenarioDefaults",
      "type": "object"
    },
    "StateSequenceExpectation": {
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "equals"
          ]
        },
        {
          "required": [
            "contains_in_order"
          ]
        }
      ],
      "properties": {
        "contains_in_order": {
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 100,
          "minItems": 1,
          "title": "Contains In Order",
          "type": "array"
        },
        "equals": {
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 100,
          "minItems": 1,
          "title": "Equals",
          "type": "array"
        }
      },
      "title": "StateSequenceExpectation",
      "type": "object"
    },
    "TextExpectation": {
      "additionalProperties": false,
      "properties": {
        "case_sensitive": {
          "default": true,
          "description": "Apply case-sensitive text checks.",
          "title": "Case Sensitive",
          "type": "boolean"
        },
        "contains": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "description": "Required substrings.",
          "title": "Contains"
        },
        "equals": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Required complete response text.",
          "title": "Equals"
        },
        "matches": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "description": "Required regular expressions.",
          "title": "Matches"
        },
        "not_contains": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "description": "Forbidden substrings.",
          "title": "Not Contains"
        }
      },
      "title": "TextExpectation",
      "type": "object"
    },
    "TextInvariant": {
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "not_contains"
          ]
        },
        {
          "required": [
            "not_contains_env"
          ]
        }
      ],
      "properties": {
        "case_sensitive": {
          "default": true,
          "description": "Apply case-sensitive checks.",
          "title": "Case Sensitive",
          "type": "boolean"
        },
        "not_contains": {
          "anyOf": [
            {
              "maxLength": 100000,
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "maxLength": 100000,
                "minLength": 1,
                "type": "string"
              },
              "maxItems": 100,
              "type": "array"
            }
          ],
          "description": "Values forbidden in every response turn.",
          "title": "Not Contains"
        },
        "not_contains_env": {
          "anyOf": [
            {
              "maxLength": 200,
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "items": {
                "maxLength": 200,
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
                "type": "string"
              },
              "maxItems": 100,
              "type": "array"
            }
          ],
          "description": "Environment variables whose values are forbidden in every response turn.",
          "title": "Not Contains Env"
        }
      },
      "title": "TextInvariant",
      "type": "object"
    },
    "Turn": {
      "additionalProperties": false,
      "properties": {
        "data": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "object"
            },
            {
              "items": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "array"
            }
          ],
          "description": "Structured data parts sent to the agent.",
          "title": "Data"
        },
        "expect": {
          "$ref": "#/$defs/Expectation",
          "description": "Expected response."
        },
        "files": {
          "description": "Local files sent as inline A2A raw parts.",
          "items": {
            "$ref": "#/$defs/FileInput"
          },
          "maxItems": 20,
          "title": "Files",
          "type": "array"
        },
        "message": {
          "anyOf": [
            {
              "maxLength": 100000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Text sent to the agent.",
          "title": "Message"
        }
      },
      "title": "Turn",
      "type": "object"
    }
  },
  "$id": "https://raw.githubusercontent.com/aspix2k/a2a-proof/main/schema/a2a-proof.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Black-box behavior contracts for one A2A agent.",
  "properties": {
    "agent": {
      "$ref": "#/$defs/AgentConfig",
      "description": "Agent discovery and transport settings."
    },
    "card": {
      "anyOf": [
        {
          "$ref": "#/$defs/AgentCardExpectation"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Agent Card preflight checks."
    },
    "defaults": {
      "$ref": "#/$defs/ScenarioDefaults",
      "description": "Defaults applied to scenarios that omit these fields."
    },
    "invariants": {
      "anyOf": [
        {
          "$ref": "#/$defs/Invariants"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Checks applied to every response turn."
    },
    "scenarios": {
      "description": "Behavior contracts to run.",
      "items": {
        "$ref": "#/$defs/Scenario"
      },
      "maxItems": 1000,
      "minItems": 1,
      "title": "Scenarios",
      "type": "array"
    },
    "version": {
      "const": 1,
      "description": "Configuration format version.",
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "version",
    "agent",
    "scenarios"
  ],
